        "id": "promptTemplate_0",
        "label": "Prompt Template",
        "version": 1,
        "name": "promptTemplate",
        "type": "PromptTemplate",
        "category": "Prompts",
        "inputs": {
          "template": "You are a world-class SEO copywriter and e-commerce specialist.\nYour task is to generate a complete SEO-optimized product description package.\n\nSTRICT RULES you MUST follow:\n1. \"title\" — a clickable SEO title. STRICTLY 60 characters or fewer. Include the main keyword naturally.\n2. \"meta_description\" — a selling meta description. STRICTLY 160 characters or fewer. Include a call-to-action and at least one keyword.\n3. \"h1\" — the main heading for the product page. Must contain the primary keyword. Must differ from the title.\n4. \"description\" — a detailed, structured product description. MUST be at least 300 characters. Use the provided keywords organically (keyword density 1-3%). Write compelling copy that sells.\n5. \"bullets\" — exactly 3 to 5 key product benefits as a bullet list. Each bullet should be concise and highlight a unique selling point.\n\nLANGUAGE: Write in the same language as the product name provided.\n\nGenerate an SEO description package for:\n\nProduct Name: {product_name}\nCategory: {category}\nKeywords: {keywords}\n\n{format_instructions}"
        },
        "inputParams": [
          {
            "label": "Template",
            "name": "template",
            "type": "string",
            "rows": 6
          }
        ],
        "inputAnchors": [
          {
            "label": "Format Instructions",
            "name": "format_instructions",
            "type": "string",
            "optional": true
          }
        ],
        "outputAnchors": [
          {
            "name": "output",
            "label": "Output",
            "type": "PromptTemplate"
          }
        ]
      }
    },
